{# Authoring-макросы для НОВЫХ страниц. Существующие страницы воспроизводятся из content/ дословно, макросы для них не нужны. #}

{% macro tldr(text) -%}
  <p class="tldr"><strong>Коротко</strong> {{ text }}</p>
{%- endmacro %}

{% macro faq_item(q, a) -%}
    <details>
      <summary>{{ q }}</summary>
      <div><p>{{ a }}</p></div>
    </details>
{%- endmacro %}

{% macro rating_card(title, desc, href, btn) -%}
    <div class="buy-card">
      <strong>{{ title }}</strong>
      <p>{{ desc }}</p>
      <a class="btn" href="{{ href }}" rel="sponsored nofollow noopener" target="_blank">{{ btn }}</a>
    </div>
{%- endmacro %}

{% macro comparison_table(caption, headers, rows) -%}
  <div class="table-wrap">
    <table>
      <caption>{{ caption }}</caption>
      <thead>
        <tr>
{%- for h in headers %}
          <th scope="col">{{ h }}</th>
{%- endfor %}
        </tr>
      </thead>
      <tbody>
{%- for row in rows %}
        <tr>
{%- for cell in row %}
          <td>{{ cell }}</td>
{%- endfor %}
        </tr>
{%- endfor %}
      </tbody>
    </table>
  </div>
{%- endmacro %}
